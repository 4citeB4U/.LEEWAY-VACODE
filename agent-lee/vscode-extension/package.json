    "onCommand:agentLee.session.pause",
    "onCommand:agentLee.session.resume",
    "onCommand:agentLee.session.stop",
    "onCommand:agentLee.session.status",
    "onCommand:agentLee.session.summary",
    "onCommand:agentLee.session.exportReceipt",
    "onCommand:agentLee.performance.setProfile",
    "onCommand:agentLee.performance.quietMode",
    "onCommand:agentLee.performance.raspberryPiMode",
    "onCommand:agentLee.performance.status",
    "onCommand:agentLee.performance.setOverride",
    "onCommand:agentLee.performance.clearOverrides",
