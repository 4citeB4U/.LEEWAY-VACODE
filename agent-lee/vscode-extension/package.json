  "contributes": {
    "chatParticipants": [
      {
        "id": "leeway.agentLee",
        "fullName": "Agent Lee",
        "name": "agentlee",
        "description": "Agent Lee LeeWay front-end engineering assistant",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentLee",
          "title": "Agent Lee",
          "icon": "media/agent-lee-activitybar.svg"
        }
      ]
    },
    "views": {
